{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["esnext", "dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "preserve",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "types": []
  },
  "include": [
    "**/*.js",
    "**/*.vue",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "unpackage",
    "dist"
  ],
  "vueCompilerOptions": {
    "experimentalCompatMode": 2
  }
}

